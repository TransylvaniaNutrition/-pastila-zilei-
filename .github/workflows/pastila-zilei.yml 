name: Pastila Zilei Test

on:
  workflow_dispatch:

jobs:
  test:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Create test email
        run: |
          cat > email.html <<'EOF'
          <html>
            <body>
              <h1>Pastila Zilei - TEST</h1>
              <p>Salut! Daca primesti acest email, workflow-ul functioneaza.</p>
            </body>
          </html>
          EOF

      - name: Send test email
        run: |
          jq -n \
            --arg from "Pastila Zilei <onboarding@resend.dev>" \
            --arg to "${{ secrets.EMAIL_TO_1 }}" \
            --arg subject "Pastila Zilei - TEST" \
            --arg html "$(cat email.html)" \
            '{from:$from,to:[$to],subject:$subject,html:$html}' > payload.json

          curl -X POST https://api.resend.com/emails \
            -H "Authorization: Bearer ${{ secrets.RESEND_API_KEY }}" \
            -H "Content-Type: application/json" \
            -d @payload.json
