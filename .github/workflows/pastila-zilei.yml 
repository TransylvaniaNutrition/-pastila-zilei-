name: Pastila Zilei Test

on:
  workflow_dispatch:

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Create test email
        run: |
          echo '<html><body><h1>Pastila Zilei - TEST</h1><p>Salut! Daca primesti acest email, workflow-ul functioneaza.</p></body></html>' > email.html

      - name: Send test email
        run: |
          curl -X POST 'https://api.resend.com/emails' \
            -H 'Content-Type: application/json' \
            -H 'Authorization: Bearer ${{ secrets.RESEND_API_KEY }}' \
            -d '{
              "from": "Pastila Zilei <onboarding@resend.dev>",
              "to": ["${{ secrets.EMAIL_TO_1 }}"],
              "subject": "Pastila Zilei - TEST",
              "html": "'"$(cat email.html)"'"
            }'
